<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <!-- TODO: Replace text logo with your actual logo image:
           <img src="/images/logo.png" alt="Tipi Raisers" class="logo-img" /> -->
      <span class="logo-icon">🏠</span>
      <span class="logo-text">Tipi <strong>Raisers</strong></span>
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </button>

    <nav class="main-nav" id="mainNav">
      <ul>
        <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a></li>
        <li><a href="/blog" class="<%= currentPath.startsWith('/blog') ? 'active' : '' %>">Blog</a></li>
        <li><a href="/progress" class="<%= currentPath === '/progress' ? 'active' : '' %>">Progress</a></li>
        <li><a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a></li>
        <li><a href="/get-involved" class="<%= currentPath === '/get-involved' ? 'active' : '' %>">Get Involved</a></li>
        <li><a href="/donate" class="nav-cta <%= currentPath === '/donate' ? 'active' : '' %>">Donate</a></li>
        <% if (isAdmin) { %>
          <li><a href="/admin" class="nav-admin">Admin</a></li>
        <% } %>
      </ul>
    </nav>
  </div>
</header>

<% if (typeof flash !== 'undefined') { %>
  <% if (flash.success && flash.success.length) { %>
    <div class="flash flash-success"><%= flash.success[0] %></div>
  <% } %>
  <% if (flash.error && flash.error.length) { %>
    <div class="flash flash-error"><%= flash.error[0] %></div>
  <% } %>
<% } %>
