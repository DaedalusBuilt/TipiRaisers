<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="page-main">
  <div class="page-hero page-hero-sm">
    <div class="container">
      <h1>Our Blog</h1>
      <p>Progress updates, community stories, and ways to get involved.</p>
    </div>
  </div>

  <div class="container blog-layout">
    <!-- Category Filter -->
    <div class="category-filter">
      <a href="/blog" class="cat-tag <%= !currentCategory ? 'cat-tag-active' : '' %>">All</a>
      <% categories.forEach(cat => { %>
        <a href="/blog?category=<%= encodeURIComponent(cat) %>"
           class="cat-tag <%= currentCategory === cat ? 'cat-tag-active' : '' %>"><%= cat %></a>
      <% }) %>
    </div>

    <!-- Posts Grid -->
    <% if (posts.length === 0) { %>
      <div class="empty-state-block">
        <p>No posts found<%= currentCategory ? ' in this category' : '' %>. Check back soon!</p>
        <a href="/blog" class="btn btn-ghost">View All Posts</a>
      </div>
    <% } else { %>
      <div class="posts-grid posts-grid-wide">
        <% posts.forEach(post => { %>
          <article class="post-card">
            <div class="post-card-img">
              <% if (post.imageUrl) { %>
                <img src="<%= post.imageUrl %>" alt="<%= post.title %>" loading="lazy" />
              <% } else { %>
                <div class="post-card-img-placeholder"></div>
              <% } %>
              <span class="post-category"><%= post.category %></span>
            </div>
            <div class="post-card-body">
              <h2><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2>
              <p class="post-excerpt"><%= post.excerpt %></p>
              <div class="post-meta">
                <span class="post-author">By <%= post.author %></span>
                <span class="post-date"><%= new Date(post.createdAt).toLocaleDateString('en-US', {month:'long',day:'numeric',year:'numeric'}) %></span>
                <a href="/blog/<%= post.slug %>" class="read-more">Read More →</a>
              </div>
            </div>
          </article>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <nav class="pagination">
          <% if (currentPage > 1) { %>
            <a href="/blog?page=<%= currentPage - 1 %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %>" class="page-btn">← Prev</a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/blog?page=<%= i %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %>"
               class="page-btn <%= i === currentPage ? 'page-btn-active' : '' %>"><%= i %></a>
          <% } %>
          <% if (currentPage < totalPages) { %>
            <a href="/blog?page=<%= currentPage + 1 %><%= currentCategory ? '&category=' + encodeURIComponent(currentCategory) : '' %>" class="page-btn">Next →</a>
          <% } %>
        </nav>
      <% } %>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
